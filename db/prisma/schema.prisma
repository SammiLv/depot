generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum RoleType {
  ADMIN
  DEPARTMENT_MANAGER
  TEAM_LEADER
  MEMBER
}

enum AnnualGoalOwnerType {
  DEPARTMENT
  TEAM
}

enum PermissionScopeType {
  SYSTEM
  DEPARTMENT
}

enum OrgPermissionModuleKey {
  ANNUAL_GOAL
  KPI
}

enum OrgPermissionAbilityKey {
  VIEW_KPI
  VIEW_KPI_TEMPLATE
  MANAGE_KPI_TEMPLATE
  TOGGLE_KPI_TEMPLATE
  INITIALIZE_KPI
  SCORE_SELF
  SCORE_LEADER
  SCORE_MANAGER
  SCORE_FINAL
}

enum OrgPermissionGrantScopeType {
  SELF
  NODE
  SUBTREE
  ALL
}

enum AnnualMetricCalculationType {
  RATIO
  BOOLEAN
  MANUAL_SCORE
}

enum ApprovalStatus {
  DRAFT
  PENDING_LEADER
  PENDING_MANAGER
  APPROVED
  REJECTED
  WITHDRAWN
}

enum WorkStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED_COMPLETED
  CLOSED
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum RiskStatus {
  NORMAL
  SLIGHT_DELAY
  RISK
  COMPLETED
}

enum KpiTemplateStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum KpiStatus {
  DRAFT
  PENDING_SELF_REVIEW
  PENDING_LEADER_SCORE
  PENDING_MANAGER_SCORE
  PENDING_FINAL_REVIEW
  COMPLETED
}

enum NotificationType {
  APPROVAL_TODO
  GOAL_UPDATE
  KPI_TODO
  WORK_DELAY
  TALENT_WARNING
  SYSTEM
}

enum OrgNodeType {
  ROOT
  DEPARTMENT
  TEAM
}

enum KpiTemplateAssignmentTargetType {
  USER
  ORG_NODE
  ROLE
}

model User {
  id                   String    @id @default(cuid())
  dingtalkUserId       String?   @unique
  loginName            String?   @unique
  passwordHash         String?
  passwordLoginEnabled Boolean   @default(false)
  name                 String
  email                String?
  mobile               String?
  avatarUrl            String?
  orgNodeId            String?
  roleType             RoleType  @default(MEMBER)
  title                String?
  joinedAt             DateTime?
  contractRenewAt      DateTime?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  @@index([orgNodeId])
  @@index([roleType])
}

model OrgNode {
  id             String      @id @default(cuid())
  dingtalkDeptId String?     @unique
  name           String
  nodeType       OrgNodeType
  parentId       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([nodeType])
  @@index([parentId])
}

model OrgClosure {
  id           String   @id @default(cuid())
  ancestorId   String
  descendantId String
  depth        Int
  createdAt    DateTime @default(now())

  @@unique([ancestorId, descendantId])
  @@index([ancestorId])
  @@index([descendantId])
  @@index([ancestorId, depth])
  @@index([descendantId, depth])
}

model MenuPermission {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  path      String
  parentId  String?
  sortOrder Int      @default(0)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleMenuPermission {
  id                  String              @id @default(cuid())
  scopeType           PermissionScopeType @default(SYSTEM)
  departmentOrgNodeId String              @default("")
  roleType            RoleType
  menuPermissionId    String
  allowed             Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([scopeType, departmentOrgNodeId, roleType, menuPermissionId])
  @@index([scopeType, departmentOrgNodeId])
  @@index([menuPermissionId])
}

model AnnualGoalPermission {
  id                    String                     @id @default(cuid())
  code                  String                     @unique
  name                  String
  description           String
  sortOrder             Int                        @default(0)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  roleAnnualPermissions RoleAnnualGoalPermission[]
}

model RoleAnnualGoalPermission {
  id                     String              @id @default(cuid())
  scopeType              PermissionScopeType @default(SYSTEM)
  departmentOrgNodeId    String              @default("")
  roleType               RoleType
  annualGoalPermissionId String
  allowed                Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  annualGoalPermission AnnualGoalPermission @relation(fields: [annualGoalPermissionId], references: [id])

  @@unique([scopeType, departmentOrgNodeId, roleType, annualGoalPermissionId])
  @@index([scopeType, departmentOrgNodeId])
  @@index([annualGoalPermissionId])
}

model OrgPermissionGrant {
  id         String                      @id @default(cuid())
  moduleKey  OrgPermissionModuleKey
  abilityKey OrgPermissionAbilityKey
  scopeType  OrgPermissionGrantScopeType
  roleType   RoleType
  orgNodeId  String?
  isActive   Boolean                     @default(true)
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  @@index([moduleKey, abilityKey, roleType, isActive])
  @@index([orgNodeId])
  @@unique([moduleKey, abilityKey, scopeType, roleType, orgNodeId])
}

model ApprovalInstance {
  id                String         @id @default(cuid())
  targetType        String
  targetId          String
  title             String
  submitterId       String
  currentApproverId String?
  status            ApprovalStatus @default(DRAFT)
  submittedAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([targetType, targetId])
  @@index([currentApproverId])
}

model ApprovalTask {
  id         String         @id @default(cuid())
  instanceId String
  approverId String
  stepName   String
  status     ApprovalStatus @default(DRAFT)
  comment    String?
  actedAt    DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([instanceId])
  @@index([approverId])
}

model AnnualGoalPlan {
  id                String              @id @default(cuid())
  year              Int
  name              String
  description       String?
  ownerType         AnnualGoalOwnerType
  ownerOrgNodeId    String?
  parentPlanId      String?
  version           Int                 @default(1)
  isActive          Boolean             @default(true)
  approvalStatus    ApprovalStatus      @default(DRAFT)
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  approvedAt        DateTime?
  revisionReason    String?
  revisedFromPlanId String?
  createdById       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  metrics AnnualGoalMetric[]

  @@index([year])
  @@index([ownerType])
  @@index([ownerOrgNodeId])
  @@index([parentPlanId])
  @@index([isActive])
}

model AnnualGoalMetricSource {
  id                String                      @id @default(cuid())
  parentMetricId    String
  metricCode        String                      @unique
  name              String
  description       String?
  targetValue       Float
  currentValue      Float                       @default(0)
  unit              String
  calculationType   AnnualMetricCalculationType @default(RATIO)
  riskStatus        RiskStatus                  @default(NORMAL)
  responsibleUserId String?
  adjustedAt        DateTime?
  progressUpdatedAt DateTime?
  createdById       String
  updatedById       String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  deletedAt         DateTime?

  parentMetric AnnualGoalMetric   @relation("AnnualGoalMetricSources", fields: [parentMetricId], references: [id])
  metrics      AnnualGoalMetric[]

  @@index([parentMetricId])
  @@index([riskStatus])
  @@index([responsibleUserId])
  @@index([deletedAt])
}

model AnnualGoalMetric {
  id                String                      @id @default(cuid())
  planId            String
  sourceMetricId    String?
  metricCode        String
  name              String
  description       String?
  targetValue       Float
  currentValue      Float                       @default(0)
  unit              String
  weight            Float
  calculationType   AnnualMetricCalculationType @default(RATIO)
  riskStatus        RiskStatus                  @default(NORMAL)
  responsibleUserId String?
  sortOrder         Int                         @default(0)
  adjustedAt        DateTime?
  progressUpdatedAt DateTime?
  createdById       String?
  updatedById       String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  deletedAt         DateTime?

  plan          AnnualGoalPlan           @relation(fields: [planId], references: [id])
  sourceMetric  AnnualGoalMetricSource?  @relation(fields: [sourceMetricId], references: [id])
  sourceMetrics AnnualGoalMetricSource[] @relation("AnnualGoalMetricSources")

  @@unique([planId, sourceMetricId])
  @@index([planId])
  @@index([sourceMetricId])
  @@index([metricCode])
  @@index([riskStatus])
  @@index([responsibleUserId])
}

model AnnualGoalQuarterTarget {
  id                String     @id @default(cuid())
  metricId          String
  sourceMetricId    String?
  year              Int
  quarter           Int
  targetValue       Float
  currentValue      Float      @default(0)
  weeklyIncrement   Float      @default(0)
  startDate         DateTime?
  endDate           DateTime?
  riskStatus        RiskStatus @default(NORMAL)
  adjustedAt        DateTime?
  progressUpdatedAt DateTime?
  createdById       String?
  updatedById       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  @@index([metricId])
  @@index([sourceMetricId])
  @@index([year, quarter])
  @@index([riskStatus])
}

model AnnualGoalProgress {
  id              String   @id @default(cuid())
  metricId        String
  sourceMetricId  String?
  quarterTargetId String?
  updaterId       String
  progressDate    DateTime
  completedValue  Float
  cumulativeValue Float
  summary         String?
  riskNote        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([metricId])
  @@index([sourceMetricId])
  @@index([quarterTargetId])
  @@index([updaterId])
}

model AnnualGoalRevisionLog {
  id             String   @id @default(cuid())
  oldPlanId      String
  newPlanId      String
  revisionReason String
  revisedById    String
  revisedAt      DateTime @default(now())

  @@index([oldPlanId])
  @@index([newPlanId])
  @@index([revisedById])
}

model Project {
  id              String        @id @default(cuid())
  title           String
  description     String?
  expectedOutcome String?
  startQuarter    String?
  endQuarter      String?
  ownerId         String
  orgNodeId       String?
  status          ProjectStatus @default(NOT_STARTED)
  createdById     String
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  quarterlyWorks QuarterlyWork[]

  @@index([ownerId])
  @@index([orgNodeId])
  @@index([status])
}

model QuarterlyWork {
  id              String         @id @default(cuid())
  projectId       String
  year            Int
  quarter         Int
  title           String
  description     String?
  workType        String?
  ownerId         String
  orgNodeId       String?
  status          WorkStatus     @default(NOT_STARTED)
  approvalStatus  ApprovalStatus @default(DRAFT)
  expectedOutcome String?
  startDate       DateTime?
  endDate         DateTime?
  createdById     String
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([year, quarter])
  @@index([ownerId])
  @@index([orgNodeId])
}

model MonthlyWorkPlan {
  id              String     @id @default(cuid())
  quarterlyWorkId String
  year            Int
  month           Int
  title           String
  description     String?
  status          WorkStatus @default(NOT_STARTED)
  expectedOutcome String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([quarterlyWorkId])
}

model WeeklyWorkUpdate {
  id                String     @id @default(cuid())
  quarterlyWorkId   String
  monthlyWorkPlanId String?
  updaterId         String
  updateDate        DateTime
  status            WorkStatus
  summary           String
  nextStep          String?
  riskNote          String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([quarterlyWorkId])
  @@index([monthlyWorkPlanId])
  @@index([updaterId])
}

model RequirementValueTrack {
  id              String    @id @default(cuid())
  projectName     String
  requirementName String
  ownerId         String
  background      String?
  expectedValue   String
  actualValue     String?
  launchDate      DateTime?
  isAchieved      Boolean?
  reviewNote      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([ownerId])
}

model KpiTemplate {
  id                  String            @id @default(cuid())
  templateKey         String
  departmentOrgNodeId String
  name                String
  description         String?
  status              KpiTemplateStatus @default(DRAFT)
  version             Int               @default(1)
  isLatest            Boolean           @default(true)
  isActive            Boolean           @default(true)
  submittedAt         DateTime?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  reviewComment       String?
  createdById         String
  updatedById         String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  @@unique([templateKey, version])
  @@index([departmentOrgNodeId, status, isActive])
  @@index([templateKey, isLatest])
  @@index([status, isActive])
  @@index([deletedAt])
  @@index([updatedById])
}

model KpiTemplateAssignment {
  id                   String                          @id @default(cuid())
  templateId           String
  targetType           KpiTemplateAssignmentTargetType
  targetUserId         String?
  targetOrgNodeId      String?
  targetRoleType       RoleType?
  effectiveFromYear    Int?
  effectiveFromQuarter Int?
  effectiveToYear      Int?
  effectiveToQuarter   Int?
  isActive             Boolean                         @default(true)
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt

  @@index([templateId])
  @@index([targetType, targetUserId])
  @@index([targetType, targetOrgNodeId])
  @@index([targetType, targetRoleType])
  @@index([isActive])
}

model KpiTemplateItem {
  id              String   @id @default(cuid())
  templateId      String
  name            String
  description     String?
  score           Float    @default(0)
  weight          Float
  scoringStandard String?
  sortOrder       Int      @default(0)
  isRequired      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([templateId])
}

model PersonalKpi {
  id              String    @id @default(cuid())
  year            Int
  quarter         Int
  userId          String
  orgNodeId       String?
  templateId      String?
  templateVersion Int?
  status          KpiStatus @default(DRAFT)
  selfScore       Float?
  leaderScore     Float?
  managerScore    Float?
  finalScore      Float?
  selfComment     String?
  leaderComment   String?
  managerComment  String?
  submittedAt     DateTime?
  completedAt     DateTime?
  initializedAt   DateTime?
  initializedById String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@unique([year, quarter, userId])
  @@index([year, quarter])
  @@index([userId])
  @@index([orgNodeId])
}

model PersonalKpiItem {
  id                     String   @id @default(cuid())
  personalKpiId          String
  sourceTemplateItemId   String?
  relatedAnnualMetricId  String?
  relatedQuarterTargetId String?
  relatedWorkId          String?
  name                   String
  description            String?
  score                  Float    @default(0)
  weight                 Float
  target                 String?
  scoringStandard        String?
  selfScore              Float?
  leaderScore            Float?
  managerScore           Float?
  finalScore             Float?
  selfComment            String?
  leaderComment          String?
  managerComment         String?
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([personalKpiId])
  @@index([relatedAnnualMetricId])
  @@index([relatedQuarterTargetId])
  @@index([relatedWorkId])
}

model PersonalKpiActionLog {
  id            String   @id @default(cuid())
  personalKpiId String
  actorId       String
  action        String
  remark        String?
  actedAt       DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([personalKpiId, actedAt])
  @@index([actorId])
}

model PersonalKpiApprovalStep {
  id            String   @id @default(cuid())
  personalKpiId String
  stepOrder     Int
  stageKey      String
  approverId    String
  status        String   @default("PENDING")
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([personalKpiId, stepOrder])
  @@index([approverId, status])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  content    String?
  targetType String?
  targetId   String?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([targetType, targetId])
}

model TodoItem {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  targetType  String
  targetId    String
  isDone      Boolean   @default(false)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([targetType, targetId])
}
